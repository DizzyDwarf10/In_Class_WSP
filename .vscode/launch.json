{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Backend",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "server/index.ts"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "autoAttachChildProcesses": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Debug Frontend",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/client",
      "command": "npm run dev"
    },
    {
      "name": "Launch Chrome (Vite)",
      "type": "msedge",
      "request": "launch",
      "preLaunchTask": "Frontend: Start Vite",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client",
      "runtimeExecutable": "C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Chrome + Backend",
      "configurations": [
        "Debug Backend",
        "Launch Chrome (Vite)"
      ],
      "stopAll": true
    }
  ]
}